# Production build config for the dashboard (Cloudflare Pages).
# VITE_API_URL is baked into the bundle at build time and points the SPA at the
# deployed Worker. Update this to the real Worker URL after `wrangler deploy`
# (Step 2 of DEPLOY.md), then rebuild + redeploy the Pages project.
VITE_API_URL=https://hailmery-api.workers.dev
