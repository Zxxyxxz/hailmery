# Copy to .env and fill in. Do NOT commit .env.
#
# Neon Postgres — use a DEV BRANCH URL (not your prod branch).
# Get from the Neon dashboard → Project → Branches → "dev" → Connection string.
# Must include `?sslmode=require` for serverless driver.
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OpenAI — for text-embedding-3-small (corpus embedding + topic embedding for RAG).
OPENAI_API_KEY=sk-...

# Anthropic — for Claude Sonnet 4.6 (generation, image prompt builder, weekly
# intelligence brief) and Haiku 4.5 (Brand Guardian).
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini) — for image generation via Gemini 3 Pro Image.
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here
IMAGE_PROVIDER=gemini
# options: gemini | gemini-flash | ideogram

# Wix Blog (V0 prototype only — used by tests/wix-blog-prototype.ts).
# Create at https://manage.wix.com/account/api-keys.
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=
